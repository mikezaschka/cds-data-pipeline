{
  "name": "cds-data-pipeline",
  "version": "0.1.0",
  "description": "A CAP application-layer plugin for declarative, traceable, scheduled data pipelines between CAP services. Each pipeline is a linear READ -> MAP -> WRITE job between exactly one source and one target, with built-in tracker, retry, concurrency guard, management OData API, and event hooks.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikezaschka/cds-data-pipeline.git"
  },
  "keywords": [
    "sap",
    "cap",
    "cds",
    "pipeline",
    "replication",
    "data-integration"
  ],
  "author": "Mike Zaschka <opensource@mikezaschka.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikezaschka/cds-data-pipeline/issues"
  },
  "homepage": "https://github.com/mikezaschka/cds-data-pipeline#readme",
  "main": "cds-plugin.js",
  "files": [
    "srv/**",
    "db/**",
    "scripts/**",
    "lib/**",
    "app/pipeline-console/**",
    "cds-plugin.js",
    "README.md"
  ],
  "workspaces": [
    "test/fixtures/consumer",
    "test/fixtures/provider",
    "test/fixtures/inventory-provider",
    "test/fixtures/rest-provider"
  ],
  "scripts": {
    "build:app-pipeline-console": "cd examples/_ui-pipeline/pipeline-console && npx ui5 build self-contained --clean-dest --dest ../../../app/pipeline-console && find ../../../app/pipeline-console -name '*.ts' -delete",
    "prepublishOnly": "npm run build:app-pipeline-console",
    "pretest": "npm install --silent",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand test/unit",
    "test:integration": "jest --runInBand test/integration",
    "docs:serve": "docker run --rm -it -p 8000:8000 -v \"$PWD:/docs\" squidfunk/mkdocs-material:9.5.44",
    "docs:build": "docker run --rm -v \"$PWD:/docs\" squidfunk/mkdocs-material:9.5.44 build --clean --strict",
    "docs:clean": "rm -rf site"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@sap/cds-dk": "^9",
    "@cap-js/mcp-server": "^0.0.4",
    "@sap-ux/fiori-mcp-server": "^0.6.49",
    "@sap/cds": "^9",
    "@ui5/mcp-server": "^0.2.11",
    "jest": "^29.7.0"
  },
  "cds": {
    "folders": {
      "db": "db",
      "srv": "srv"
    },
    "requires": {
      "DataPipelineService": {
        "impl": "cds-data-pipeline/srv/DataPipelineService.js"
      }
    }
  },
  "peerDependencies": {
    "@sap/cds": ">=9.2.0",
    "@sap/cds-dk": ">=9"
  },
  "peerDependenciesMeta": {
    "@sap/cds-dk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
